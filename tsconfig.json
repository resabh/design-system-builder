{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@dsb/providers": ["packages/providers/src"],
      "@dsb/core": ["packages/core/src"],
      "@dsb/cli": ["packages/cli/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
